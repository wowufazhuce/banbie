---
import { type BitsEntry, getBitAnchorId } from '../lib/bits';
import { createWithBase, formatDateTime } from '../utils/format';
import { getThemeSettings } from '../lib/theme-settings';

const {
  bit,
  excerpt = '',
  Content = null,
  prioritizeLeadMedia = false
} = Astro.props;

const bitEntry = bit as BitsEntry;

const tags = bit.data.tags ?? [];
const placeTag = tags.find((t: string) => t.toLowerCase().startsWith('loc:')) ?? '';
const placeText = placeTag ? placeTag.slice(4).trim() : '';
const normalTags = tags.filter((t: string) => !t.toLowerCase().startsWith('loc:'));
const normalTagItems: string[] = normalTags.map((t: string) => `#${t}`);
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { settings } = getThemeSettings();
const defaultAuthorName = (settings.page.bits.defaultAuthor.name ?? 'Whono').trim() || 'Whono';
const authorName = (bit.data.author?.name ?? defaultAuthorName).trim() || defaultAuthorName;
const authorAvatarRaw = (bit.data.author?.avatar ?? settings.page.bits.defaultAuthor.avatar ?? '').trim();
const authorAvatar = authorAvatarRaw ? withBase(authorAvatarRaw) : '';
const avatarLetter = Array.from(authorName)[0] ?? 'W';
type BitImage = { src: string; width: number; height: number; alt?: string };
const images = (bit.data.images ?? []) as BitImage[];
const imageItems = images.map((image) => ({
  ...image,
  src: withBase(image.src)
}));
const maxVisible = 4;
const visibleImages = imageItems.slice(0, maxVisible);
const firstImage = imageItems.length === 1 ? imageItems[0] : null;
const totalImages = imageItems.length;
const wideIndex = totalImages > 1 && totalImages <= maxVisible && totalImages % 2 === 1 ? 0 : -1;
const hasTags = Boolean(placeText || normalTagItems.length);
const getImageLoading = (prioritize: boolean) => (prioritize ? 'eager' : 'lazy');
const getImageFetchPriority = (prioritize: boolean) => (prioritize ? 'high' : undefined);
---

<article
  class="bit-card"
  id={getBitAnchorId(bitEntry.id)}
  data-bit
  data-bit-key={bitEntry.id}
  data-slug={bitEntry.data.slug ?? bitEntry.id}
>
  <div class="bit-author">
    <div class={`avatar${authorAvatar ? ' avatar--image' : ' is-fallback'}`} aria-hidden="true">
      {authorAvatar ? (
        <img
          src={authorAvatar}
          alt=""
          width="32"
          height="32"
          loading="lazy"
          decoding="async"
          onerror="this.parentElement?.classList.add('is-fallback'); this.remove();"
        />
      ) : null}
      <span class="avatar-fallback">{avatarLetter}</span>
    </div>
    <div class="name">{authorName}</div>
  </div>

  {Content ? (
    <div class="bit-body">
      <Content />
    </div>
  ) : excerpt ? (
    <div class="bit-body">
      <p>{excerpt}</p>
    </div>
  ) : null}

  {firstImage ? (
    <div class="bit-media bit-media--single">
      <button
        type="button"
        class="bit-media-item bit-media-item--single"
        data-bit-image-button
        data-bit-image-index="0"
        aria-label="查看图片预览"
      >
        <img
          src={firstImage.src}
          alt={firstImage.alt ?? ''}
          width={firstImage.width}
          height={firstImage.height}
          loading={getImageLoading(prioritizeLeadMedia)}
          fetchpriority={getImageFetchPriority(prioritizeLeadMedia)}
        />
      </button>
    </div>
  ) : imageItems.length > 1 ? (
    <div class="bit-media bit-media--grid">
      <div class="bit-media-grid">
        {visibleImages.map((image, index) => {
          const isMore = index === maxVisible - 1 && imageItems.length > maxVisible;
          return (
            <button
              type="button"
              class={`bit-media-item${index === wideIndex ? ' bit-media-item--wide' : ''}${isMore ? ' bit-media-item--more' : ''}`}
              data-bit-image-button
              data-bit-image-index={index}
              aria-label={isMore ? `查看全部图片（共 ${imageItems.length} 张）` : `图片 ${index + 1}`}
            >
              <img
                src={image.src}
                alt={image.alt ?? ''}
                width={image.width}
                height={image.height}
                loading={getImageLoading(prioritizeLeadMedia && index === 0)}
                fetchpriority={getImageFetchPriority(prioritizeLeadMedia && index === 0)}
              />
              {isMore ? (
                <>
                  <span class="bit-media-more" aria-hidden="true" data-bit-image-open-hidden={maxVisible}>
                    <span class="bit-media-more-short">+ {imageItems.length - maxVisible}</span>
                    <span class="bit-media-more-full">查看其余{imageItems.length - maxVisible}张</span>
                  </span>
                </>
              ) : null}
            </button>
          );
        })}
      </div>
    </div>
  ) : null}

  {imageItems.length ? (
    <div hidden aria-hidden="true">
      {imageItems.map((image) => (
        <span
          data-bit-image-item
          data-bit-image-src={image.src}
          data-bit-image-alt={image.alt ?? ''}
          data-bit-image-width={image.width}
          data-bit-image-height={image.height}
        ></span>
      ))}
    </div>
  ) : null}

  <div class="bit-meta">
    {hasTags ? (
      <div class="bit-tags">
        {placeText ? (
          <span class="bit-tag bit-tag--place">
            <span class="bit-tag-icon" aria-hidden="true">📍</span>
            <span class="bit-tag-text">{placeText}</span>
          </span>
        ) : null}
        {normalTagItems.length ? (
          <span class="bit-tag bit-tag--normal">
            <span class="bit-tag-icon" aria-hidden="true">❤</span>
            <span class="bit-tag-list">
              {normalTagItems.map((tag) => (
                <span class="bit-tag-token">{tag}</span>
              ))}
            </span>
          </span>
        ) : null}
      </div>
    ) : null}
    <div>{formatDateTime(bit.data.date)}</div>
  </div>
</article>
