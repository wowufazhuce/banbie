---
import {
  ADMIN_HERO_IMAGE_ALT_DEFAULT,
  ADMIN_HERO_IMAGE_ALT_MAX_LENGTH,
  ADMIN_HOME_INTRO_LINK_DEFAULT,
  ADMIN_HOME_INTRO_LINK_OPTIONS
} from '../../lib/admin-console/shared';

interface Props {
  homeIntroMaxLength: number;
}

const { homeIntroMaxLength } = Astro.props;
---

<fieldset class="admin-group">
  <legend class="admin-group__legend">
    <span class="admin-group__legend-zh">首页设置</span>
    <span class="admin-group__legend-sep" aria-hidden="true">·</span>
    <span class="admin-group__legend-en">Home</span>
  </legend>
  <div class="admin-grid">
    <div class="admin-field admin-field--full">
      <div class="admin-hero-grid">
        <span class="admin-label__copy admin-hero-grid__copy">
          <label class="admin-label__main" for="home-hero-image-src">Hero 图片地址</label>
          <span class="admin-label__hint">（地址留空时回退内置默认图）</span>
        </span>
        <label class="admin-label__main admin-hero-grid__heading" for="home-hero-image-alt">Hero 图片说明</label>
        <label class="admin-label__toggle admin-hero-grid__toggle" for="home-show-hero">
          <input id="home-show-hero" type="checkbox" checked />
          <span>展示</span>
        </label>
        <input
          id="home-hero-image-src"
          class="admin-hero-grid__input admin-hero-grid__input--primary"
          type="text"
          inputmode="url"
          spellcheck="false"
          placeholder="当前使用：src/assets/hero.png"
          aria-label="Hero 图片地址"
        />
        <input
          id="home-hero-image-alt"
          class="admin-hero-grid__input admin-hero-grid__input--secondary"
          type="text"
          maxlength={ADMIN_HERO_IMAGE_ALT_MAX_LENGTH}
          placeholder={ADMIN_HERO_IMAGE_ALT_DEFAULT}
          aria-label="Hero 图片说明"
        />
      </div>
      <p class="admin-help">注：支持 src/assets/**、public/** 或 https:// 图床链接</p>
    </div>
    <div class="admin-field admin-field--full">
      <div class="admin-label admin-label--split">
        <span class="admin-label__copy">
          <label class="admin-label__main" for="home-intro-lead">首页导语主文案</label>
        </span>
        <label class="admin-label__toggle" for="home-show-intro-lead">
          <input id="home-show-intro-lead" type="checkbox" checked />
          <span>展示</span>
        </label>
      </div>
      <textarea id="home-intro-lead" rows="3" maxlength={homeIntroMaxLength}></textarea>
    </div>
    <div class="admin-field admin-field--full">
      <div class="admin-label admin-label--split">
        <span class="admin-label__copy">
          <label class="admin-label__main" for="home-intro-more">首页导语补充文案</label>
          <span class="admin-label__hint">（固定句式：补充文案 + 链接 + 可选“或” + 链接）</span>
        </span>
        <label class="admin-label__toggle" for="home-show-intro-more">
          <input id="home-show-intro-more" type="checkbox" checked />
          <span>展示</span>
        </label>
      </div>
      <div class="admin-inline-builder admin-inline-builder--intro-more" role="group" aria-label="首页导语补充句式编辑器">
        <textarea
          id="home-intro-more"
          class="admin-inline-builder__text"
          rows="1"
          maxlength={homeIntroMaxLength}
          aria-label="首页导语补充文案"
        ></textarea>
        <span class="admin-inline-builder__select-group">
          <select
            id="home-intro-more-link-primary"
            class="admin-inline-builder__select"
            aria-label="首页导语补充主链接"
          >
            {ADMIN_HOME_INTRO_LINK_OPTIONS.map((option) => (
              <option value={option.id} selected={option.id === ADMIN_HOME_INTRO_LINK_DEFAULT[0]}>
                {option.label}
              </option>
            ))}
          </select>
        </span>
        <span class="admin-inline-builder__divider" aria-hidden="true">|</span>
        <label class="admin-inline-builder__toggle" for="home-intro-more-link-secondary-enabled">
          <input
            id="home-intro-more-link-secondary-enabled"
            type="checkbox"
            aria-controls="home-intro-more-link-secondary"
          />
          <span>启用双链接</span>
        </label>
        <span
          id="home-intro-more-link-secondary-group"
          class="admin-inline-builder__secondary"
          aria-disabled="true"
        >
          <span class="admin-inline-builder__secondary-sep">或</span>
          <select
            id="home-intro-more-link-secondary"
            class="admin-inline-builder__select"
            aria-label="首页导语补充第二链接"
            disabled
          >
            {ADMIN_HOME_INTRO_LINK_OPTIONS.map((option) => (
              <option value={option.id} selected={option.id === ADMIN_HOME_INTRO_LINK_DEFAULT[1]}>
                {option.label}
              </option>
            ))}
          </select>
        </span>
      </div>
      <p class="admin-help">
        补充导语预览：<code id="home-intro-more-preview" class="admin-help__preview-value">更多文章请访问 归档。</code>
      </p>
    </div>
  </div>
</fieldset>
