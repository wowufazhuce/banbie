interface Props {
  name: IconName;
  size?: number | string;
  class?: string;
  ariaLabel?: string;
}

const {
  name,
  size,
  class: className = '',
  ariaLabel
} = Astro.props as Props;

const iconSize = size ?? 24;
const ariaHidden = ariaLabel ? undefined : 'true';
const role = ariaLabel ? 'img' : undefined;
const normalizedName =
  name === 'x-twitter'
    ? 'x'
