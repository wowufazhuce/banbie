---
import type { ImageMetadata } from 'astro';
import { Picture } from 'astro:assets';
import defaultHero from '@/assets/hero.png';
import { createWithBase, normalizeHeroImageSrc } from '../utils/format';

interface Props {
  alt?: string;
  isLCP?: boolean;
  src?: string | null;
}

const {
  alt = 'Whono theme preview',
  isLCP = false,
  src = null
} = Astro.props;

const heroAssets = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/**/*.{avif,gif,jpeg,jpg,png,webp}',
  { eager: true }
);

const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);

const normalizedAlt = typeof alt === 'string' && alt.trim() ? alt.trim() : 'Whono theme preview';
const normalizedSrc = normalizeHeroImageSrc(src) ?? null;

const resolveHeroAssetKey = (value: string | null): string | null => {
  if (!value?.startsWith('src/assets/')) return null;
  return `../${value.slice('src/'.length)}`;
};

const heroAssetKey = resolveHeroAssetKey(normalizedSrc);
const heroAssetModule = heroAssetKey ? heroAssets[heroAssetKey] : undefined;
const heroAsset = heroAssetModule?.default ?? null;

const resolvedImgSrc = normalizedSrc
  ? normalizedSrc.startsWith('src/assets/')
    ? null
    : normalizedSrc.startsWith('/')
      ? withBase(normalizedSrc)
      : normalizedSrc
  : null;

---

{
  heroAsset ? (
    <Picture
      src={heroAsset}
      alt={normalizedAlt}
      widths={[360, 480, 640, 768, 900, 1200]}
      sizes="(max-width: 768px) 92vw, 900px"
      formats={['avif', 'webp']}
      loading={isLCP ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={isLCP ? 'high' : undefined}
    />
  ) : resolvedImgSrc ? (
    <img
      src={resolvedImgSrc}
      alt={normalizedAlt}
      loading={isLCP ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={isLCP ? 'high' : undefined}
    />
  ) : (
    <Picture
      src={defaultHero}
      alt={normalizedAlt}
      widths={[360, 480, 640, 768, 900, 1200]}
      sizes="(max-width: 768px) 92vw, 900px"
      formats={['avif', 'webp']}
      loading={isLCP ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={isLCP ? 'high' : undefined}
    />
  )
}
