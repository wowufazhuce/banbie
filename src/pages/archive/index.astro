---
import ArchivePageView from '../../components/ArchivePageView.astro';
import { getArchiveEssays, getPageSlice, getTotalPages } from '../../lib/content';
import { collectTagSummary } from '../../lib/tags';
import { PAGE_SIZE_ARCHIVE } from '../../../site.config.mjs';

const archiveItems = await getArchiveEssays();
const tagSummaries = collectTagSummary(archiveItems);
const totalPages = getTotalPages(archiveItems.length, PAGE_SIZE_ARCHIVE);
const currentPage = 1;
const pageItems = getPageSlice(archiveItems, currentPage, PAGE_SIZE_ARCHIVE);
---

<ArchivePageView
  items={pageItems}
  resultCount={archiveItems.length}
  currentPage={currentPage}
  totalPages={totalPages}
  currentPath="/archive/"
  prevPath={null}
  nextPath={currentPage < totalPages ? `/archive/page/${currentPage + 1}/` : null}
  tagSummaries={tagSummaries}
/>
