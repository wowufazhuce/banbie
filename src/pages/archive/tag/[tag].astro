---
import ArchivePageView from '../../../components/ArchivePageView.astro';
import { getArchiveEssays, getPageSlice, getTotalPages } from '../../../lib/content';
import { collectTagSummary, filterEntriesByTag, findTagSummary, getTagPath } from '../../../lib/tags';
import { PAGE_SIZE_ARCHIVE } from '../../../../site.config.mjs';

export const prerender = true;

export async function getStaticPaths() {
  const archiveItems = await getArchiveEssays();
  const tagSummaries = collectTagSummary(archiveItems);
  return tagSummaries.map((tagSummary) => ({
    params: {
      tag: tagSummary.key
    }
  }));
}

const archiveItems = await getArchiveEssays();
const tagSummaries = collectTagSummary(archiveItems);
const currentTag = findTagSummary(tagSummaries, Astro.params.tag ?? '');

if (!currentTag) {
  throw new Error(`Unknown archive tag: ${Astro.params.tag ?? ''}`);
}

const filteredItems = filterEntriesByTag(archiveItems, currentTag.key);
const totalPages = getTotalPages(filteredItems.length, PAGE_SIZE_ARCHIVE);
const currentPage = 1;
const pageItems = getPageSlice(filteredItems, currentPage, PAGE_SIZE_ARCHIVE);
---

<ArchivePageView
  items={pageItems}
  resultCount={filteredItems.length}
  currentPage={currentPage}
  totalPages={totalPages}
  currentPath={getTagPath('archive', currentTag.key)}
  prevPath={null}
  nextPath={currentPage < totalPages ? getTagPath('archive', currentTag.key, currentPage + 1) : null}
  tagSummaries={tagSummaries}
  currentTag={currentTag}
/>
