---
import BitsPageView from '../../../components/BitsPageView.astro';
import { buildPaginatedPaths } from '../../../lib/content';
import { getBitsPageData, getBitsPagePath } from '../../../lib/bits';
import { PAGE_SIZE_BITS } from '../../../../site.config.mjs';

export const prerender = true;

export async function getStaticPaths() {
  const { totalPages } = await getBitsPageData(1, PAGE_SIZE_BITS);
  return buildPaginatedPaths(totalPages);
}

const currentPage = Number(Astro.params.page);
const { items, yearOptions, totalCount, totalPages } = await getBitsPageData(currentPage, PAGE_SIZE_BITS);

if (!Number.isInteger(currentPage) || currentPage <= 1 || currentPage > totalPages) {
  throw new Error(`Unknown bits page: ${Astro.params.page ?? ''}`);
}

---

<BitsPageView
  items={items}
  resultCount={totalCount}
  currentPage={currentPage}
  totalPages={totalPages}
  yearOptions={yearOptions}
  prevPath={currentPage === 2 ? getBitsPagePath(1) : getBitsPagePath(currentPage - 1)}
  nextPath={currentPage < totalPages ? getBitsPagePath(currentPage + 1) : null}
/>
