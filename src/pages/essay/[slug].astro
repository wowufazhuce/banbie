---
import { getVisibleEssayRouteEntries } from '../../lib/content';

export const prerender = true;

export async function getStaticPaths() {
  const routeEntries = await getVisibleEssayRouteEntries();
  return routeEntries.map(({ slug }) => {
    return {
      params: { slug },
      props: { slug }
    };
  });
}

return Astro.redirect(
  `${(import.meta.env.BASE_URL ?? '/').replace(/\/?$/, '/')}archive/${Astro.params.slug}/`,
  301
);
---
