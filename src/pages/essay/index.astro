---
import EssayPageView from '../../components/EssayPageView.astro';
import { getPageSlice, getTotalPages, getVisibleEssays } from '../../lib/content';
import { PAGE_SIZE_ESSAY } from '../../../site.config.mjs';

const visibleEssays = await getVisibleEssays();
const totalPages = getTotalPages(visibleEssays.length, PAGE_SIZE_ESSAY);
const currentPage = 1;
const pageEssays = getPageSlice(visibleEssays, currentPage, PAGE_SIZE_ESSAY);
---

<EssayPageView
  items={pageEssays}
  resultCount={visibleEssays.length}
  currentPage={currentPage}
  totalPages={totalPages}
  prevPath={null}
  nextPath={currentPage < totalPages ? `/essay/page/${currentPage + 1}/` : null}
/>
